{
  "name": "@noodlestan/eslint-config",
  "version": "0.0.6",
  "description": "Noodlestan's opinionated style guide configuration (ESLint + Prettier).",
  "author": "Noodlestan Collective",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/noodlestan/eslint-config"
  },
  "main": ".eslintrc.cjs",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "LICENSE-MIT"
  ],
  "scripts": {
    "lint": "prettier . -c && eslint .",
    "lint:silent": "prettier . -c --log-level silent && eslint .",
    "test": "npm run lint"
  },
  "dependencies": {
    "@typescript-eslint/eslint-plugin": "8.11.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-mdx": "3.8.1",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-solid": "0.14.5"
  },
  "peerDependencies": {
    "eslint": "^8.57.1",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/eslint": "9.6.1",
    "@types/node": "25.9.3",
    "@typescript-eslint/parser": "8.61.0",
    "lefthook": "2.1.9",
    "eslint": "8.57.1",
    "solid-js": "1.9.13"
  },
  "engines": {
    "node": "24.15.0"
  }
}
